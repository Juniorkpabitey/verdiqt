VITE_SUPABASE_URL=https://your-project.supabase.co

# Use either name — match what your Supabase dashboard shows:
# - New projects: Publishable key → VITE_SUPABASE_PUBLISHABLE_KEY
# - Legacy tab: anon key (JWT) → VITE_SUPABASE_ANON_KEY
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
# VITE_SUPABASE_ANON_KEY=eyJ...
